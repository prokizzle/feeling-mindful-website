{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; [[ \"$file\" == *.tsx || \"$file\" == *.ts || \"$file\" == *.css || \"$file\" == *.json || \"$file\" == *.md ]] && npx prettier --write \"$file\" 2>/dev/null; exit 0"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=\"$CLAUDE_FILE_PATH\"; [[ \"$file\" == *.tsx || \"$file\" == *.ts ]] && npx eslint --fix \"$file\" 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_FILE_PATH\" | grep -qE '(\\.env|\\.env\\..+|package-lock\\.json)$' && echo 'BLOCK: Protected file — edit manually or use Bash' && exit 2 || exit 0"
          }
        ]
      }
    ]
  }
}
